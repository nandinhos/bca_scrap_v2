{
    "name": "gacpac/bca-scrap-v2",
    "type": "project",
    "description": "Sistema de Busca e Análise de Boletins de Comando da Aeronáutica - Laravel 12 TALL Stack",
    "keywords": ["laravel", "livewire", "tall-stack", "gac-pac", "bca"],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.9",

        "livewire/livewire": "^4.0",
        "laravel/horizon": "^5.27",
        "laravel/sanctum": "^4.0",

        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-backup": "^9.0",
        "spatie/laravel-query-builder": "^6.0",

        "guzzlehttp/guzzle": "^7.8",
        "symfony/process": "^7.0",

        "smalot/pdfparser": "^2.9",

        "predis/predis": "^2.2",

        "maatwebsite/excel": "^3.1",

        "wire-elements/modal": "^2.0",
        "filament/notifications": "^3.2"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",

        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.3",
        "pestphp/pest-plugin-livewire": "^2.1",

        "nunomaduro/collision": "^8.0",
        "nunomaduro/larastan": "^2.9",

        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",

        "barryvdh/laravel-debugbar": "^3.13",
        "spatie/laravel-ray": "^1.36"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "test": "pest",
        "test:coverage": "pest --coverage --min=80",
        "format": "pint",
        "analyse": "phpstan analyse",
        "ci": [
            "@format",
            "@analyse",
            "@test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
