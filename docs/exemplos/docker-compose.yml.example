version: '3.8'

###############################################################################
# BCA Scrap v2 - Docker Compose
# Stack: Laravel 12 + PostgreSQL 16 + Redis 7 + Nginx
###############################################################################

services:

  # ===========================================================================
  # Nginx - Web Server
  # ===========================================================================
  nginx:
    image: nginx:alpine
    container_name: bca-nginx
    restart: unless-stopped
    ports:
      - "8080:80"
    volumes:
      - ./:/var/www/html
      - ./docker/nginx/default.conf:/etc/nginx/conf.d/default.conf
      - ./storage/logs/nginx:/var/log/nginx
    depends_on:
      - php
    networks:
      - bca-network

  # ===========================================================================
  # PHP-FPM 8.3
  # ===========================================================================
  php:
    build:
      context: .
      dockerfile: docker/php/Dockerfile
    container_name: bca-php
    restart: unless-stopped
    working_dir: /var/www/html
    volumes:
      - ./:/var/www/html
      - ./storage/app/bcas:/var/www/html/storage/app/bcas
    environment:
      # Laravel
      - APP_ENV=${APP_ENV:-local}
      - APP_DEBUG=${APP_DEBUG:-true}
      - APP_URL=${APP_URL:-http://localhost:8080}

      # Database
      - DB_CONNECTION=pgsql
      - DB_HOST=postgres
      - DB_PORT=5432
      - DB_DATABASE=${DB_DATABASE:-bca_db}
      - DB_USERNAME=${DB_USERNAME:-bca_user}
      - DB_PASSWORD=${DB_PASSWORD:-bca_pass}

      # Redis
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_PASSWORD=${REDIS_PASSWORD:-null}

      # Queue
      - QUEUE_CONNECTION=redis

      # Mail
      - MAIL_MAILER=${MAIL_MAILER:-smtp}
      - MAIL_HOST=${MAIL_HOST:-smtp.fab.mil.br}
      - MAIL_PORT=${MAIL_PORT:-587}
      - MAIL_USERNAME=${MAIL_USERNAME}
      - MAIL_PASSWORD=${MAIL_PASSWORD}
      - MAIL_FROM_ADDRESS=${MAIL_FROM_ADDRESS}
      - MAIL_FROM_NAME="${MAIL_FROM_NAME:-Sistema BCA GAC-PAC}"

      # BCA Scrap
      - CENDOC_URL=${CENDOC_URL:-http://www.cendoc.intraer/sisbca/consulta_bca/}
      - ICEA_URL=${ICEA_URL:-http://www.icea.intraer/app/arcadia/busca_bca/boletim_bca/}
    depends_on:
      - postgres
      - redis
    networks:
      - bca-network

  # ===========================================================================
  # PostgreSQL 16
  # ===========================================================================
  postgres:
    image: postgres:16-alpine
    container_name: bca-postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${DB_DATABASE:-bca_db}
      POSTGRES_USER: ${DB_USERNAME:-bca_user}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-bca_pass}
      POSTGRES_INITDB_ARGS: "--encoding=UTF8 --locale=pt_BR.UTF-8"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./docker/postgres/init.sql:/docker-entrypoint-initdb.d/init.sql
    ports:
      - "5432:5432"
    networks:
      - bca-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USERNAME:-bca_user}"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ===========================================================================
  # pgAdmin 4
  # ===========================================================================
  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: bca-pgadmin
    restart: unless-stopped
    environment:
      PGADMIN_DEFAULT_EMAIL: ${PGADMIN_EMAIL:-admin@gacpac.fab.mil.br}
      PGADMIN_DEFAULT_PASSWORD: ${PGADMIN_PASSWORD:-admin123}
      PGADMIN_CONFIG_SERVER_MODE: 'False'
      PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED: 'False'
    ports:
      - "5050:80"
    volumes:
      - pgadmin_data:/var/lib/pgadmin
    depends_on:
      - postgres
    networks:
      - bca-network

  # ===========================================================================
  # Redis 7 (Cache + Queue)
  # ===========================================================================
  redis:
    image: redis:7-alpine
    container_name: bca-redis
    restart: unless-stopped
    command: redis-server --appendonly yes --requirepass ${REDIS_PASSWORD:-null}
    volumes:
      - redis_data:/data
    ports:
      - "6379:6379"
    networks:
      - bca-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ===========================================================================
  # Horizon (Laravel Queue Worker)
  # ===========================================================================
  horizon:
    build:
      context: .
      dockerfile: docker/php/Dockerfile
    container_name: bca-horizon
    restart: unless-stopped
    working_dir: /var/www/html
    command: php artisan horizon
    volumes:
      - ./:/var/www/html
    environment:
      - DB_CONNECTION=pgsql
      - DB_HOST=postgres
      - REDIS_HOST=redis
      - QUEUE_CONNECTION=redis
      - MAIL_MAILER=${MAIL_MAILER:-smtp}
      - MAIL_HOST=${MAIL_HOST}
      - MAIL_PORT=${MAIL_PORT}
      - MAIL_USERNAME=${MAIL_USERNAME}
      - MAIL_PASSWORD=${MAIL_PASSWORD}
    depends_on:
      - postgres
      - redis
    networks:
      - bca-network
    healthcheck:
      test: ["CMD-SHELL", "php artisan horizon:status | grep running"]
      interval: 30s
      timeout: 10s
      retries: 3

  # ===========================================================================
  # Scheduler (Laravel CRON)
  # ===========================================================================
  scheduler:
    build:
      context: .
      dockerfile: docker/php/Dockerfile
    container_name: bca-scheduler
    restart: unless-stopped
    working_dir: /var/www/html
    command: >
      sh -c "while true; do
        php artisan schedule:run --verbose --no-interaction &
        sleep 60
      done"
    volumes:
      - ./:/var/www/html
    environment:
      - DB_CONNECTION=pgsql
      - DB_HOST=postgres
      - REDIS_HOST=redis
    depends_on:
      - postgres
      - redis
    networks:
      - bca-network

  # ===========================================================================
  # Redis Commander (opcional - UI para Redis)
  # ===========================================================================
  redis-commander:
    image: rediscommander/redis-commander:latest
    container_name: bca-redis-commander
    restart: unless-stopped
    environment:
      - REDIS_HOSTS=local:redis:6379
    ports:
      - "8081:8081"
    depends_on:
      - redis
    networks:
      - bca-network
    profiles:
      - dev

###############################################################################
# Networks
###############################################################################
networks:
  bca-network:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16

###############################################################################
# Volumes (Persistência de Dados)
###############################################################################
volumes:
  postgres_data:
    driver: local
  pgadmin_data:
    driver: local
  redis_data:
    driver: local
