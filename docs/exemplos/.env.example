# ============================================
# BCA Scrap v2 - Laravel 12 TALL Stack
# Configuração de Ambiente
# ============================================

APP_NAME="BCA Scrap GAC-PAC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8080
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

# ============================================
# Database (PostgreSQL)
# ============================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bca_db
DB_USERNAME=bca_user
DB_PASSWORD=bca_pass

# ============================================
# Cache & Session (Redis)
# ============================================
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ============================================
# Email (SMTP FAB)
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.fab.mil.br
MAIL_PORT=587
MAIL_USERNAME=fernandofss@fab.mil.br
MAIL_PASSWORD=MNIGABTPLESDSNDK
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=fernandofss@fab.mil.br
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# Queue & Horizon
# ============================================
HORIZON_PREFIX=bca-horizon
HORIZON_BALANCE=auto
HORIZON_MAX_PROCESSES=10
HORIZON_TIMEOUT=300
HORIZON_TRIES=3

# ============================================
# BCA Scrap - Configurações Específicas
# ============================================

# URLs de busca
CENDOC_URL=http://www.cendoc.intraer/sisbca/consulta_bca/
ICEA_URL=http://www.icea.intraer/app/arcadia/busca_bca/boletim_bca/

# Diretórios
BCA_STORAGE_PATH=storage/app/bcas
BCA_CACHE_TTL=2592000  # 30 dias em segundos

# Performance
BCA_PARALLEL_DOWNLOADS=true
BCA_PARALLEL_CHUNK_SIZE=50
BCA_DOWNLOAD_TIMEOUT=5  # segundos
BCA_MAX_RETRIES=3

# Limpeza automática
BCA_KEEP_DAYS=30
BCA_AUTO_CLEANUP=true

# Notificações
BCA_EMAIL_QUEUE=emails
BCA_EMAIL_RETRY_TIMES=3
BCA_EMAIL_RETRY_DELAY=300  # 5 minutos

# ============================================
# Logging
# ============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null

# ============================================
# Broadcasting (opcional - Pusher/Echo)
# ============================================
BROADCAST_CONNECTION=log
# BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=mt1

# ============================================
# Filesystem
# ============================================
FILESYSTEM_DISK=local

# AWS S3 (se usar no futuro)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# Vite
# ============================================
VITE_APP_NAME="${APP_NAME}"

# ============================================
# Telescope & Debugbar (desenvolvimento)
# ============================================
TELESCOPE_ENABLED=true
DEBUGBAR_ENABLED=true

# ============================================
# Monitoramento (produção)
# ============================================
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=1.0

# ============================================
# Performance Tuning
# ============================================
OCTANE_SERVER=swoole  # ou roadrunner
SCOUT_DRIVER=database  # ou algolia/meilisearch

# ============================================
# Segurança
# ============================================
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

# ============================================
# Backup
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 2h da manhã
BACKUP_DISK=local
BACKUP_KEEP_DAYS=7
